<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ splash. Light mode: cream bg with the Kovira K
         visible only — the icon-background-color matches the splash
         background so the system's mandatory circle is invisible. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:windowSplashScreenBackground">#fffefe</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#fffefe</item>
    </style>
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/white</item>
    </style>
</resources>
